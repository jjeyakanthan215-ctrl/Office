{
    "builds": [
          {
                  "src": "esctrix/wsgi.py",
                  "use": "@vercel/python"
          },
          {
                  "src": "build_files.sh",
                  "use": "@vercel/static-build",
                  "config": {
                            "distDir": "staticfiles"
                  }
          }
    ],
    "routes": [
          {
                  "src": "/static/(.*)",
                  "dest": "/$1"
          },
          {
                  "src": "/(.*)",
                  "dest": "esctrix/wsgi.py"
          }
    ]
}
